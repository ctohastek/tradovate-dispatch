# agents.yaml.example
# Agent configuration file
# Copy to agents.yaml and configure your agents

agents:
  mini01:
    name: "mini01"
    api_key: "mini01-api-key-here"
    appId: "mini01"  # Tradovate API appId (nickname of API key)
    environment: "demo"  # demo or live
    rate_limit_override: 20
    max_contracts_allowed: 6
    enabled: true

  mini02:
    name: "mini02"
    api_key: "mini02-api-key-here"
    appId: "mini02"  # Tradovate API appId
    environment: "demo"  # demo or live
    rate_limit_override: 20
    max_contracts_allowed: 6
    enabled: false

  mini03:
    name: "mini03"
    api_key: "mini03-api-key-here"
    appId: "mini03"  # Tradovate API appId
    environment: "demo"  # demo or live
    rate_limit_override: 20
    max_contracts_allowed: 6
    enabled: false
