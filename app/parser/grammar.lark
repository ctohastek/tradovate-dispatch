?start: command

command: buy | sell | cancel | status | help

buy: "BUY" quantity contract price?
sell: "SELL" quantity contract price?
cancel: "CANCEL" order_id
status: "STATUS" order_id?
help: "HELP"

quantity: NUMBER
contract: CONTRACT
price: "AT"i NUMBER
order_id: /\w+/

CONTRACT: /[A-Z]{1,5}/
NUMBER: /\d+(\.\d+)?/

%import common.WS
%ignore WS
