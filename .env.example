# .env.example
# Copy to .env and configure with actual values

# ============================================================================
# TRADOVATE API CONFIGURATION
# ============================================================================
# Tradovate API Base URLs
TRADOVATE_LIVE_URL="https://live.tradovateapi.com/"
TRADOVATE_DEMO_URL="https://demo.tradovateapi.com/"

# Shared authentication credentials for all agents
# TRADOVATE_ACCOUNT_NAME: Username used during API key authentication (typically first agent name, e.g., mini01)
# TRADOVATE_ACCOUNT_PASS: Password set during API key generation in Tradovate dashboard
TRADOVATE_ACCOUNT_NAME="mini01"
TRADOVATE_ACCOUNT_PASS="your-api-password-set-during-key-generation"

# Device ID: Unique identifier for this system
# Required for two-factor authentication with Tradovate
TRADOVATE_DEVICE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Per-agent API credentials (generate in Tradovate dashboard under API Access)
# Each agent (mini01, mini02, mini03) must have its own API key and Client ID
TRADOVATE_API_KEY_MINI01="your-api-secret-mini01"
TRADOVATE_API_KEY_MINI02="your-api-secret-mini02"
TRADOVATE_API_KEY_MINI03="your-api-secret-mini03"

TRADOVATE_CLIENT_ID_mini01="your-client-id-mini01"
TRADOVATE_CLIENT_ID_mini02="your-client-id-mini02"
TRADOVATE_CLIENT_ID_mini03="your-client-id-mini03"

# Agent environments are configured in agents.yaml, not .env

# ============================================================================
# DISPATCHER SECURITY
# ============================================================================
# API key for this dispatcher service (clients must provide this in Authorization header)
DISPATCHER_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL="sqlite:///dispatcher.db"

# ============================================================================
# RATE LIMITING
# ============================================================================
# Requests per minute limit (per agent)
RATE_LIMIT_REQUESTS_PER_MINUTE=10

# ============================================================================
# ALERTS / EMAIL
# ============================================================================
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_TO="dispatch-alerts@your.domain"
ALERT_EMAIL_FROM="tradovatedispatch@your.domain"
ALERT_SMTP_HOST="127.0.0.1 or FQDN"
ALERT_SMTP_PORT="xxxx"
ALERT_SMTP_PASSWORD="your-smtp-password-if-needed"

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE="logs/dispatcher.log"

# ============================================================================
# SERVER
# ============================================================================
DEBUG=false
HOST="127.0.0.1"
PORT="8000"
WORKERS=4
