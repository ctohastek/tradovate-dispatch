# .env.example
# Copy to .env and configure with actual values


# Tradovate API Endpoints
TRADOVATE_LIVE_URL=https://live.tradovateapi.com/
TRADOVATE_DEMO_URL=https://demo.tradovateapi.com/

TRADOVATE_DEVICE_ID=

TRADOVATE_API_KEY_mini01=
TRADOVATE_API_KEY_mini02=
TRADOVATE_API_KEY_mini03=

TRADOVATE_CLIENT_ID_mini01=
TRADOVATE_CLIENT_ID_mini02=
TRADOVATE_CLIENT_ID_mini03=

TRADOVATE_ACCOUNT_NAME=
TRADOVATE_ACCOUNT_PASS=

# Agent Environments
AGENT_ENVIRONMENT_mini01=demo
AGENT_ENVIRONMENT_mini02=demo
AGENT_ENVIRONMENT_mini03=demo


# tradovate-dispatch key
DISPATCHER_API_KEY=221d524aa69a29c14ecbd0f046565ff751bce829a1683d967f0dd40f50fc72f8


# Database
DATABASE_URL=sqlite:///dispatcher.db

# Rate Limiting (requests per minute)
RATE_LIMIT_REQUESTS_PER_MINUTE=10

# Alerts
ALERT_EMAIL_ENABLED=true
ALERT_EMAIL_TO=dispatch-alert@hastek.net
ALERT_EMAIL_FROM=tradovatedispatch@hastek.net
ALERT_SMTP_HOST=127.0.0.1
ALERT_SMTP_PORT=1025
ALERT_SMTP_PASSWORD='smtp relay has separate auth in place, submissions do not need creds'

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/dispatcher.log

DEBUG=false

# Server
HOST=127.0.0.1
PORT=8000
WORKERS=4

